# ChatAnalysis — environment configuration
# Copy this file to .env and fill in your values.

# ── LLM endpoint for skill-mining (any OpenAI-compatible API) ──
# Required only for the `semantic-run --method skill-mining --backend pydantic-ai` workflow.
# The fixture backend works without any API key.
CHATANALYSIS_LLM_BASE_URL=https://api.openai.com/v1
CHATANALYSIS_LLM_API_KEY=sk-your-key-here
CHATANALYSIS_LLM_MODEL=gpt-4o-mini

# ── Embedding model for clustering (optional) ──
# Used by the semantic-local clustering/embedding backends and the analysis notebook.
# Default: all-MiniLM-L6-v2 (free, ~23 MB, downloads automatically on first use).
# Alternatives: NovaSearch/stella_en_1.5B_v5, BAAI/bge-small-en-v1.5, etc.
CHATANALYSIS_EMBEDDING_MODEL=all-MiniLM-L6-v2
